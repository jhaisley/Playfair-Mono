{
code = "sub f idotaccent by fi;\nsub longs idotaccent by longs_i.liga;\n\n# For f_f_x ligatures\nlookup double_f {\nsub f' [f_adieresis.liga f_idieresis.liga f_igrave.liga f_odieresis.liga f_thorn.liga f_b.liga f_h.liga fi f_j.liga f_k.liga fl f_udieresis.liga f_ydieresis.liga f_t.liga] by f_init.ligature;\nsub f_init.ligature [f_adieresis.liga f_idieresis.liga f_igrave.liga f_odieresis.liga f_thorn.liga f_b.liga f_h.liga fi f_j.liga f_k.liga fl f_udieresis.liga f_ydieresis.liga f_t.liga]' by [_f_adieresis.ligature _f_idieresis.ligature _f_igrave.ligature _f_odieresis.ligature _f_thorn.ligature _f_b.ligature _f_h.ligature _f_i.ligature _f_j.ligature _f_k.ligature _f_l.ligature _f_udieresis.ligature _f_ydieresis.ligature _f_t.ligature];\n} double_f;\n\n# For f_f ligatures\nlookup first_f {\n	sub f' f by f_init.ligature;\n} first_f;\nlookup second_f {\n	sub f_init.ligature f' by f-fina.ligature ;\n} second_f;\n\n# For longs_longs_x ligatures\nlookup double_longs {\nsub longs' [longs_i.liga longs_l.liga longs_h.liga longs_k.liga longs_t.liga] by longs-init.ligature;\nsub longs-init.ligature [longs_i.liga longs_l.liga longs_h.liga longs_k.liga longs_t.liga]' by [_longs_i.ligature _longs_l.ligature _longs_h.ligature _longs_k.ligature _longs_t.liga];\n} double_longs;\n\n# For longs_longs ligatures\nlookup first_longs {\n	sub longs' longs by longs-init.ligature;\n} first_longs;\nlookup second_longs {\n	sub longs-init.ligature longs' by longs-fina.ligature;\n} second_longs;\n";
